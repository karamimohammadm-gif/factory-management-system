function editPart(id) {
    if(currentUser?.role !== "admin" && currentUser?.role !== "warehouse") { alert("شما دسترسی ویرایش قطعات را ندارید"); return; }
    let p = partsInventory.find(p => p.id === id);
    if(!p) return;
    let newQty = prompt("مقدار جدید موجودی:", p.quantity);
    if(newQty !== null && !isNaN(parseFloat(newQty))) {
        let oldQty = p.quantity;
        p.quantity = parseFloat(newQty);
        partMovements.push({ id: nextMovementId++, partId: p.id, type: "adjust", quantity: Math.abs(p.quantity - oldQty), date: getCurrentPersianDate(), description: `ویرایش موجودی از ${oldQty} به ${p.quantity}`, operator: currentUser?.name });
        renderPartsStats(); renderPartsInventoryList(); renderPartMovementsList(); saveLocal();
        alert("✅ موجودی بروزرسانی شد");
    }
}
function showPartMovementForm(partId, type) {
    let part = partsInventory.find(p => p.id === partId);
    if(!part) return;
    let qty = parseFloat(prompt(`${type === "in" ? "ورود" : "خروج"} قطعه "${part.name}" - مقدار ${type === "out" ? `(حداکثر ${part.quantity})` : ""}:`));
    if(isNaN(qty) || qty <= 0) { alert("مقدار نامعتبر"); return; }
    if(type === "out" && qty > part.quantity) { alert("موجودی کافی نیست"); return; }
    if(type === "in") part.quantity += qty;
    else part.quantity -= qty;
    partMovements.push({ id: nextMovementId++, partId: part.id, type: type, quantity: qty, date: getCurrentPersianDate(), description: `${type === "in" ? "ورود" : "خروج"}`, operator: currentUser?.name });
    renderPartsStats(); renderPartsInventoryList(); renderPartMovementsList(); saveLocal();
    alert(`✅ ${type === "in" ? "ورود" : "خروج"} ${formatNumber(qty)} ثبت شد`);
}
function showPartMovementForWarehouse() {
    if(partsInventory.length === 0) { alert("هیچ قطعه‌ای وجود ندارد"); return; }
    let partList = "";
    for(let i = 0; i < partsInventory.length; i++) { partList += `${i+1}. ${partsInventory[i].name} (موجودی: ${partsInventory[i].quantity})\n`; }
    let partIndex = prompt(`قطعه مورد نظر را انتخاب کنید:\n${partList}\nشماره قطعه را وارد کنید:`);
    if(!partIndex) return;
    let idx = parseInt(partIndex) - 1;
