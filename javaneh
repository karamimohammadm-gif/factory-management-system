        .parts-request-modal-content { background: white; border-radius: 24px; padding: 30px; width: 550px; max-height: 85vh; overflow: auto; }
        .tabs-mini { display: flex; gap: 8px; margin-bottom: 20px; border-bottom: 2px solid #e8f5e9; padding-bottom: 8px; flex-wrap: wrap; }
        .tab-mini-btn { background: transparent; border: none; padding: 10px 20px; font-size: 0.9rem; font-weight: 600; color: #6b8c5c; cursor: pointer; border-radius: 30px; transition: all 0.2s; }
        .tab-mini-btn:hover { background: #f1f8e9; color: #2e7d32; }
        .tab-mini-btn.active { background: #2e7d32; color: white; }
