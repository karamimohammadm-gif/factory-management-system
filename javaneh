function loadLocal() { 
    let s = localStorage.getItem(SHARED_STORAGE_KEY); 
    if(s) { 
        try { 
            let d = JSON.parse(s); 
            if(d.formulas) formulas = d.formulas; 
            if(d.devices) devices = d.devices; 
            if(d.inventory) inventory = d.inventory; 
            if(d.productTypes) productTypes = d.productTypes; 
            if(d.incomingMaterials) incomingMaterials = d.incomingMaterials; 
            if(d.materialTests) materialTests = d.materialTests; 
            if(d.finalQcTests) finalQcTests = d.finalQcTests; 
            if(d.customerFeedbacks) customerFeedbacks = d.customerFeedbacks; 
            if(d.productInventory) productInventory = d.productInventory; 
            if(d.productHistory) productHistory = d.productHistory; 
            if(d.materialRequests) materialRequests = d.materialRequests; 
            if(d.nextFormulaId) nextFormulaId = d.nextFormulaId; 
            if(d.nextDeviceId) nextDeviceId = d.nextDeviceId; 
            if(d.nextInventoryId) nextInventoryId = d.nextInventoryId; 
            if(d.currentFormulaId) currentFormulaId = d.currentFormulaId; 
            if(d.systemSettings) systemSettings = d.systemSettings; 
            if(d.systemLogs) systemLogs = d.systemLogs; 
            if(d.traceabilityData) traceabilityData = d.traceabilityData;
            if(d.partsInventory) partsInventory = d.partsInventory;
            if(d.partMovements) partMovements = d.partMovements;
            if(d.partRequests) partRequests = d.partRequests;
            if(d.nextPartId) nextPartId = d.nextPartId;
            if(d.nextMovementId) nextMovementId = d.nextMovementId;
            if(d.nextPartRequestId) nextPartRequestId = d.nextPartRequestId;
            if(d.materialPriceHistory) materialPriceHistory = d.materialPriceHistory;
            if(d.materialReturns) materialReturns = d.materialReturns;
            if(d.nextReturnId) nextReturnId = d.nextReturnId;
            if(d.complaints) complaints = d.complaints;
            if(d.nextComplaintId) nextComplaintId = d.nextComplaintId;
            if(!currentFormulaId || !formulas.find(f => f.id === currentFormulaId)) currentFormulaId = formulas[0]?.id || 1;
        } catch(e) { console.error("خطا در بارگذاری:", e); } 
    } 
    if(formulas.length === 0) {
        formulas = [{ id: 1, orderCode: "ORD-001", name: "سفارش نمونه", priority: "normal", description: "", includeBobbin: false, bobbinWeightPerRoll: 0, status: STATUS_OBJ.WAITING_MATERIALS, productTypeCode: "SH", uvPercent: 0, color: "شفاف", selectedDeviceId: 1, orderQuantity: 5000, actualProducedQuantity: null, wasteQuantity: 0, packWeight: 25, length: 1000, lengthUnit: "cm", width: 50, thickness: 30, materials: [{ code: "RM-1001", name: "مواد0075", quantity: 350, price: 28500 }], materialsConfirmedAt: null, materialsConfirmedBy: null, productionConfirmedAt: null, productionConfirmedBy: null, sentToQcAt: null, productionBatchNo: null, finalQcDate: null, deliveryDate: null, priceFinalized: false, createdAt: new Date().toISOString(), persianCreatedAt: toPersianDate(new Date().toISOString()), requestedMaterials: null, usedMaterialLots: null }];
        if(inventory.length === 0) inventory = [{ id: 1, code: "RM-1001", name: "مواد0075", quantity: 10000, minStock: 1000, location: "قفسه A1", basePrice: 28500, priceUpdatedAt: new Date().toISOString(), lots: [] }];
    }
    renderAll(); 
}
function buildTabsMenu() {
    const allTabs = [ { id: "formulas", name: "📋 سفارشات" }, { id: "production-manager", name: "👨‍🏭 مدیر تولید" }, { id: "devices", name: "🏭 سربار تولید" }, { id: "calculation", name: "🧮 محاسبه هزینه" }, { id: "inventory", name: "📦 انبار" }, { id: "warehouse-operations", name: "📦 عملیات انبار" }, { id: "incoming-inspection", name: "📥 بازرسی مواد ورودی" }, { id: "quality-control", name: "🔬 کنترل کیفی مواد" }, { id: "final-qc", name: "✅ کنترل کیفی خروجی" }, { id: "delivery", name: "🚚 تحویل و رضایتمندی" }, { id: "comparison", name: "📊 مقایسه نیاز" }, { id: "reports", name: "📈 گزارشات مدیریتی" }, { id: "traceability", name: "🔍 ردیابی" }, { id: "complaints", name: "📝 رسیدگی به شکایات" } ];
    let extraTabs = [];
    if(currentUser?.role === "admin") extraTabs = [ { id: "material-prices", name: "💰 مدیریت قیمت مواد" }, { id: "system-settings", name: "⚙️ تنظیمات سیستم" }, { id: "parts-warehouse", name: "🔧 انبار قطعات" } ];
    if(currentUser?.role === "warehouse") extraTabs = [ { id: "parts-warehouse", name: "🔧 انبار قطعات" } ];
    let tabs = [...allTabs, ...extraTabs];
    let perm = rolePermissionsMap[currentUser?.role];
    let filteredTabs = tabs.filter(tab => perm && perm[tab.id] === true);
    let dropdown = document.getElementById("tabsDropdown");
    if(dropdown) { dropdown.innerHTML = ''; for(let t of filteredTabs) { let btn = document.createElement('button'); btn.className = 'tab-btn'; btn.setAttribute('data-tab', t.id); btn.innerHTML = t.name; btn.onclick = (function(id){ return function(){ switchTab(id); toggleTabsMenu(); }; })(t.id); dropdown.appendChild(btn); } }
    let desktop = document.getElementById("tabsDesktop");
    if(desktop) { desktop.innerHTML = ''; for(let t of filteredTabs) { let btn = document.createElement('button'); btn.className = 'tab-btn'; btn.setAttribute('data-tab', t.id); btn.innerHTML = t.name; btn.onclick = (function(id){ return function(){ switchTab(id); }; })(t.id); desktop.appendChild(btn); } }
}
function applyPermissions() { if(!currentUser) return; let perm = rolePermissionsMap[currentUser.role]; document.querySelectorAll('.tab-btn').forEach(btn => { let tn = btn.getAttribute('data-tab'); if(perm && perm[tn]) { btn.classList.remove('disabled'); btn.style.display = 'flex'; } else { btn.classList.add('disabled'); btn.style.display = 'none'; } }); buildTabsMenu(); }
function switchTab(tabName) { 
    if(!currentUser) return; 
    let perm = rolePermissionsMap[currentUser.role]; 
    if(!perm || !perm[tabName]) { alert("شما دسترسی به این بخش را ندارید"); return; } 
    document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active')); 
    document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active')); 
    let tp=document.getElementById(`tab-${tabName}`); 
    if(tp) tp.classList.add('active'); 
    let btns=document.querySelectorAll(`.tab-btn[data-tab="${tabName}"]`); 
    btns.forEach(b=>b.classList.add('active')); 
    if(tabName==='calculation') calculateFull(); 
    if(tabName==='inventory') { inventoryCurrentPage = 1; renderInventory(); renderProductInventory(); renderProductHistoryList(); } 
    if(tabName==='warehouse-operations') { searchProductForOperation(); renderWarehouseMaterialRequestsList(); renderProductHistoryList(); } 
    if(tabName==='comparison') renderComparison(); 
    if(tabName==='formulas') { renderFormulasList(); renderCurrentFormulaEditor(); updateMaterialSelectors(); } 
    if(tabName==='production-manager') { renderFormulasListNoPrice(); renderCurrentFormulaEditorNoPrice(); updateMaterialSelectors(); updateDeviceSelectorForFormula(); updateProductionManagerInfo(); renderPendingProductionOrders(); renderMaterialRequestsList(); } 
    if(tabName==='devices') renderDevices(); 
    if(tabName==='incoming-inspection') { renderIncomingMaterialsList(); } 
    if(tabName==='quality-control') { renderPendingQcMaterials(); renderMaterialTestsHistory(); } 
    if(tabName==='final-qc') { renderFinalQcOrdersList(); renderFinalQcHistoryList(); } 
    if(tabName==='delivery') { renderDeliveryOrdersList(); renderCustomerFeedbackList(); } 
    if(tabName==='reports') generateFullReport(); 
    if(tabName==='traceability') { showAllTraceBatches(); } 
    if(tabName==='system-settings' && currentUser?.role === "admin") { renderSystemSettings(); renderProductTypesManager(); }
    if(tabName==='material-prices' && currentUser?.role === "admin") { renderMaterialPricesList(); renderMaterialPriceHistory(); }
    if(tabName==='parts-warehouse') { renderPartsStats(); partsInventoryCurrentPage = 1; renderPartsInventoryList(); renderPartRequestsList(); partsMovementsCurrentPage = 1; renderPartMovementsList(); }
    if(tabName==='complaints') { complaintsCurrentPage = 1; renderComplaintsList(); renderComplaintStats(); }
    let dd=document.getElementById("tabsDropdown"); 
    if(dd&&dd.classList.contains("open")) dd.classList.remove("open"); 
}
function doLogin() {
    let un = document.getElementById("loginUsername").value.trim();
    let pw = document.getElementById("loginPassword").value;
    let err = document.getElementById("loginError");
    console.log("Login attempt:", un);
    let user = USERS_FULL.find(u => u.username === un && u.password === pw);
    if(user){
        console.log("Login SUCCESS:", user.name);
        currentUser = {...user};
        localStorage.setItem("JavanehCurrentUserV21", JSON.stringify({ username: user.username, name: user.name, role: user.role }));
        document.getElementById("loginOverlay").style.display = "none";
        document.getElementById("appContainer").style.display = "block";
        document.getElementById("currentUserName").innerText = user.name;
        let rp = { admin: "مدیر سیستم", operator: "مدیر تولید", warehouse: "انباردار", quality: "مدیر کیفیت", sales: "واحد فروش" };
        let re = document.getElementById("currentUserRole");
        if(re){ re.innerText = rp[user.role]; re.className = `badge ${user.role === 'admin' ? 'badge-success' : (user.role === 'operator' ? 'badge-warning' : (user.role === 'quality' ? 'badge-info' : 'badge-danger'))}`; }
        loadLocal();
        applyPermissions();
        startAutoSync();
        if(Notification.permission === "default") Notification.requestPermission();
        integrateTraceability();
        setTimeout(() => { renderAll(); }, 100);
    } else {
        console.log("Login FAILED for:", un);
        if(err) err.innerText = "❌ نام کاربری یا رمز عبور اشتباه است";
    }
}
function logout() { 
    currentUser=null; 
    localStorage.removeItem("JavanehCurrentUserV21"); 
    document.getElementById("loginOverlay").style.display="flex"; 
    document.getElementById("appContainer").style.display="none"; 
    document.getElementById("loginUsername").value="admin"; 
    document.getElementById("loginPassword").value="0306230"; 
    document.getElementById("loginError").innerText=""; 
}
