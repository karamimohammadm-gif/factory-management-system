function saveComplaint() {
    let id = document.getElementById("editComplaintId").value;
    let customerName = document.getElementById("complaintCustomerName").value.trim();
    let subject = document.getElementById("complaintSubject").value.trim();
    let description = document.getElementById("complaintDescription").value.trim();
    let priority = document.getElementById("complaintPriority").value;
    let assignedTo = document.getElementById("complaintAssignedTo").value;
    if(!customerName || !subject || !description) { alert("لطفاً نام مشتری، موضوع و شرح شکایت را وارد کنید"); return; }
    let now = new Date();
    if(id) {
        let complaint = complaints.find(c => c.id == id);
        if(complaint) {
            complaint.customerName = customerName;
            complaint.subject = subject;
            complaint.description = description;
            complaint.priority = priority;
            complaint.assignedTo = assignedTo;
            if(complaint.status === "new" && (currentUser?.role === "quality" || currentUser?.role === "admin")) {
                let actionTaken = document.getElementById("complaintActionTaken").value.trim();
                let finalResult = document.getElementById("complaintFinalResult").value;
                let actionDate = document.getElementById("complaintActionDate").value;
                let additionalNote = document.getElementById("complaintAdditionalNote").value;
                if(actionTaken) {
                    complaint.actionTaken = actionTaken;
                    complaint.finalResult = finalResult;
                    complaint.actionDate = actionDate ? actionDate : now.toISOString().slice(0,10);
                    complaint.additionalNote = additionalNote;
                    complaint.status = finalResult === "resolved" ? "resolved" : (finalResult === "partial" ? "in_progress" : "closed");
                    complaint.resolvedAt = now.toISOString();
                    complaint.resolvedBy = currentUser?.name;
                    complaint.persianResolvedAt = getCurrentPersianDateTime();
                    systemLogs.push({ id: systemLogs.length+1, action: "اقدام اصلاحی شکایت", details: `شکایت #${complaint.complaintNumber} - ${complaint.subject}`, date: now.toISOString(), user: currentUser?.name, persianDate: toPersianDate(now.toISOString()) });
                }
            }
            if(complaint.status === "resolved" && (currentUser?.role === "sales" || currentUser?.role === "admin")) {
                let satisfaction = parseInt(document.getElementById("complaintCustomerSatisfaction").value);
                let feedbackDate = document.getElementById("complaintFeedbackDate").value;
                let customerComment = document.getElementById("complaintCustomerComment").value;
                if(satisfaction) {
                    complaint.customerSatisfaction = satisfaction;
                    complaint.customerFeedbackDate = feedbackDate ? feedbackDate : now.toISOString().slice(0,10);
                    complaint.customerComment = customerComment;
                    complaint.status = "closed";
                    complaint.closedAt = now.toISOString();
                    complaint.closedBy = currentUser?.name;
                    complaint.persianClosedAt = getCurrentPersianDateTime();
                    systemLogs.push({ id: systemLogs.length+1, action: "بستن شکایت با بازخورد مشتری", details: `شکایت #${complaint.complaintNumber} با امتیاز ${satisfaction}`, date: now.toISOString(), user: currentUser?.name, persianDate: toPersianDate(now.toISOString()) });
                }
            }
            saveLocal();
            renderComplaintsList();
            renderComplaintStats();
            renderAll();
            alert(`✅ شکایت #${complaint.complaintNumber} بروزرسانی شد`);
        }
    } else {
        let complaintNumber = `CMP-${String(nextComplaintId).padStart(4,'0')}`;
        let newComplaint = {
            id: nextComplaintId++,
            complaintNumber: complaintNumber,
            customerName: customerName,
            subject: subject,
            description: description,
            priority: priority,
            assignedTo: assignedTo,
            status: "new",
            createdAt: now.toISOString(),
            persianCreatedAt: getCurrentPersianDateTime(),
            createdBy: currentUser?.name,
            actionTaken: null,
            finalResult: null,
            actionDate: null,
            additionalNote: null,
            resolvedAt: null,
            resolvedBy: null,
            persianResolvedAt: null,
            customerSatisfaction: null,
            customerFeedbackDate: null,
            customerComment: null,
            closedAt: null,
            closedBy: null,
            persianClosedAt: null
        };
        complaints.push(newComplaint);
        systemLogs.push({ id: systemLogs.length+1, action: "ثبت شکایت جدید", details: `شکایت ${complaintNumber}: ${subject}`, date: now.toISOString(), user: currentUser?.name, persianDate: toPersianDate(now.toISOString()) });
        saveLocal();
        renderComplaintsList();
        renderComplaintStats();
        renderAll();
        alert(`✅ شکایت با شماره ${complaintNumber} ثبت شد`);
    }
    closeComplaintModal();
}
