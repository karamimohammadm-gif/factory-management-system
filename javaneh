    material.basePrice = newPrice;
    material.priceUpdatedAt = new Date().toISOString();
    systemLogs.push({ id: systemLogs.length + 1, action: "تغییر قیمت ماده", details: `${material.name} (${material.code}): از ${formatNumber(oldPrice)} به ${formatNumber(newPrice)} تومان/کیلو`, date: new Date().toISOString(), user: currentUser?.name, persianDate: toPersianDate(new Date().toISOString()) });
