function approveMaterialRequest(reqId) { 
    if(!rolePermissionsMap[currentUser?.role]?.canApproveMaterialRequests) { alert("شما دسترسی تایید درخواست مواد را ندارید"); return; } 
    let req = materialRequests.find(r => r.id === reqId); 
    if(!req || req.status !== "pending") { alert("درخواست یافت نشد"); return; } 
    let fulfilled = [], allFull = true, any = false; 
    for(let it of req.items) { 
        let inp = document.getElementById(`fulfill_${req.id}_${it.materialCode}`); 
        let q = parseFloat(inp?.value) || 0; 
        if(q > 0) { 
            any = true; 
            let inv = inventory.find(i => i.code === it.materialCode); 
            if(inv && inv.quantity >= q) { 
                inv.quantity -= q; 
                if(!inv.lots) inv.lots = [];
                let existingLot = inv.lots.find(l => l.lotNumber === `LOT-${req.formulaName}-${Date.now()}`);
                if(!existingLot) {
                    let newLot = { lotNumber: `LOT-${req.formulaName}-${Date.now()}`, remainingQuantity: q, addedAt: new Date().toISOString() };
                    inv.lots.push(newLot);
                } else {
                    existingLot.remainingQuantity += q;
                }
            } 
            else if(inv) { alert(`موجودی کافی برای ${it.materialCode} وجود ندارد!`); return; } 
            fulfilled.push({ materialCode: it.materialCode, materialName: it.materialName, requestedQuantity: it.requestedQuantity, fulfilledQuantity: q }); 
            if(q < it.requestedQuantity) allFull = false; 
        } else { allFull = false; } 
    } 
    if(!any) { alert("لطفاً حداقل یک ماده را تامین کنید"); return; } 
    req.status = allFull ? "approved" : "partially_fulfilled"; 
    req.fulfilledItems = fulfilled; 
    req.approvedBy = currentUser?.name; 
    req.approvedAt = new Date().toISOString(); 
    req.persianApprovedAt = getCurrentPersianDateTime(); 
    let formula = formulas.find(f => f.id === req.formulaId);
    if(formula && formula.requestedMaterials) {
        for(let f of formula.requestedMaterials) {
            let ful = fulfilled.find(fi => fi.materialCode === f.materialCode);
            if(ful) { f.fulfilledQuantity = ful.fulfilledQuantity; }
        }
    }
    renderWarehouseMaterialRequestsList(); 
    renderMaterialRequestsList(); 
    renderInventory(); 
    saveLocal(); 
    alert(`✅ درخواست برای "${req.formulaName}" تایید شد.`); 
}
function rejectMaterialRequest(reqId) { 
    if(!rolePermissionsMap[currentUser?.role]?.canApproveMaterialRequests) { alert("شما دسترسی رد درخواست را ندارید"); return; } 
    let req = materialRequests.find(r => r.id === reqId); 
