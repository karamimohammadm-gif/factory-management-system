        .pagination button { padding: 8px 14px; border: 1px solid #dde8dc; background: white; border-radius: 12px; cursor: pointer; }
        .pagination button.active { background: #2e7d32; color: white; border-color: #2e7d32; }
        .pagination .page-info { margin: 0 10px; font-size: 0.8rem; color: #666; }
        .inspection-card { background: #fff8e1; border-radius: 16px; padding: 16px; margin-bottom: 12px; border-right: 4px solid #ff9800; }
        .equipment-card { background: #f8faf5; border-radius: 20px; padding: 20px; text-align: center; transition: all 0.2s; border: 2px solid #e8f0e8; }
        .status-led { width: 14px; height: 14px; border-radius: 50%; display: inline-block; margin-left: 6px; }
