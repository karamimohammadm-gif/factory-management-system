    if(invTab) invTab.classList.remove("active");
    if(reqTab) reqTab.classList.remove("active");
    if(movTab) movTab.classList.remove("active");
    if(tabName === "inventory" && invTab) invTab.classList.add("active");
    if(tabName === "requests" && reqTab) reqTab.classList.add("active");
    if(tabName === "movements" && movTab) movTab.classList.add("active");
    document.querySelectorAll(".tab-mini-btn").forEach(btn => btn.classList.remove("active"));
    let activeBtn = document.querySelector(`.tab-mini-btn[data-tab="${tabName}"]`);
    if(activeBtn) activeBtn.classList.add("active");
    if(tabName === "inventory") { partsInventoryCurrentPage = 1; renderPartsInventoryList(); }
    if(tabName === "requests") renderPartRequestsList();
    if(tabName === "movements") { partsMovementsCurrentPage = 1; renderPartMovementsList(); }
}
