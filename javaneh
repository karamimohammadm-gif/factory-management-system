function openApproveModal(requestId) {
    let req = partRequests.find(r => r.id === requestId);
    if(!req) return;
    let similarPart = partsInventory.find(p => p.name === req.itemName || p.name.includes(req.itemName));
    let maxQty = similarPart ? similarPart.quantity : req.quantity;
    let fulfillQty = parseFloat(prompt(`مقدار تامین برای "${req.itemName}":\nدرخواست: ${req.quantity} ${req.unit}\nموجودی انبار: ${similarPart ? similarPart.quantity : 0} ${similarPart ? similarPart.unit : req.unit}`, Math.min(req.quantity, maxQty)));
    if(isNaN(fulfillQty) || fulfillQty <= 0) { alert("مقدار نامعتبر"); return; }
    if(similarPart) {
        if(fulfillQty > similarPart.quantity) { alert("موجودی کافی نیست"); return; }
        similarPart.quantity -= fulfillQty;
        partMovements.push({ id: nextMovementId++, partId: similarPart.id, type: "out", quantity: fulfillQty, date: getCurrentPersianDate(), description: `تامین درخواست #${req.requestNumber}`, operator: currentUser?.name });
    }
    req.status = fulfillQty >= req.quantity ? "approved" : "partially_fulfilled";
    req.fulfilledQuantity = fulfillQty;
    req.approvedBy = currentUser?.name;
    renderPartsStats(); renderPartsInventoryList(); renderPartRequestsList(); renderPartMovementsList(); saveLocal();
    alert(`✅ درخواست "${req.itemName}" تامین شد.`);
}
function rejectPartRequest(requestId) {
    let req = partRequests.find(r => r.id === requestId);
    if(!req || req.status !== "pending") return;
    req.status = "rejected";
    req.rejectedBy = currentUser?.name;
    renderPartRequestsList(); saveLocal();
    alert(`❌ درخواست "${req.itemName}" رد شد.`);
}
function switchPartsTab(tabName) {
    let invTab = document.getElementById("partsInventoryTab");
