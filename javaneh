function submitOperation() { 
    if(!selectedProductForOperation || !selectedOperation) { alert("لطفاً محصول و نوع عملیات را انتخاب کنید"); return; } 
    let oldLocation = selectedProductForOperation.location;
    let operationDescription = "";
    if(selectedOperation === "in") { 
        let q = parseFloat(document.getElementById("opQuantity").value); 
        let loc = document.getElementById("opLocation").value; 
        if(isNaN(q) || q <= 0) { alert("مقدار معتبر وارد کنید"); return; } 
        selectedProductForOperation.quantity += q; 
        if(loc) selectedProductForOperation.location = loc; 
        operationDescription = document.getElementById("opDescription").value;
        addProductHistory(selectedProductForOperation.id, selectedProductForOperation.productName, "in", q, null, loc, currentUser?.name, operationDescription);
        alert(`✅ ${formatNumber(q)} کیلو اضافه شد.`); 
    } else if(selectedOperation === "out") { 
        let q = parseFloat(document.getElementById("opQuantity").value); 
        let avail = selectedProductForOperation.quantity - (selectedProductForOperation.reserved || 0); 
        if(isNaN(q) || q <= 0) { alert("مقدار معتبر وارد کنید"); return; } 
        if(q > avail) { alert(`حداکثر موجودی قابل خروج: ${formatNumber(avail)} کیلو`); return; } 
        selectedProductForOperation.quantity -= q; 
        operationDescription = document.getElementById("opDescription").value;
        addProductHistory(selectedProductForOperation.id, selectedProductForOperation.productName, "out", q, selectedProductForOperation.location, null, currentUser?.name, operationDescription);
        let relatedFormula = formulas.find(f => f.id === selectedProductForOperation.orderId);
        if(relatedFormula && relatedFormula.status === STATUS_OBJ.QC_APPROVED) {
            relatedFormula.status = STATUS_OBJ.READY_FOR_FEEDBACK;
            relatedFormula.deliveryDate = new Date().toISOString();
            relatedFormula.persianDeliveryDate = getCurrentPersianDate();
            saveLocal();
            alert(`✅ سفارش "${relatedFormula.name}" از انبار خارج شد و آماده ثبت نظر مشتری است.`);
        }
        alert(`✅ ${formatNumber(q)} کیلو کسر شد.`); 
    } else if(selectedOperation === "move") { 
        let nloc = document.getElementById("opToLocation").value; 
        if(!nloc) { alert("مکان جدید را وارد کنید"); return; } 
        operationDescription = document.getElementById("opDescription").value;
        addProductHistory(selectedProductForOperation.id, selectedProductForOperation.productName, "move", 0, oldLocation, nloc, currentUser?.name, operationDescription);
        selectedProductForOperation.location = nloc; 
        alert(`✅ محصول به "${nloc}" منتقل شد.`); 
    } 
    renderProductInventory(); 
    renderProductHistoryList();
    renderDeliveryOrdersList();
    saveLocal(); 
    cancelOperation(); 
    selectProductForOperation(); 
}
