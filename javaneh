function deliverOrder(fid) { 
    let f = formulas.find(f => f.id === fid); 
    if(f && f.status === STATUS_OBJ.QC_APPROVED) { 
        let prod = productInventory.find(p => p.orderId === f.id); 
        if(prod) { 
            let qty = f.actualProducedQuantity || f.orderQuantity || 5000; 
            if(prod.quantity >= qty) { 
                prod.quantity -= qty; 
                f.status = STATUS_OBJ.READY_FOR_FEEDBACK; 
                f.deliveryDate = new Date().toISOString(); 
                f.persianDeliveryDate = toPersianDate(new Date().toISOString()); 
                f.deliveredBy = currentUser?.name; 
                let productBatch = traceabilityData.batches.find(b => b.sourceId === f.id && b.type === 'product');
                if(productBatch) { productBatch.customerName = f.name; productBatch.status = 'delivered'; saveTraceData(); }
                saveLocal(); renderAll(); 
                alert(`✅ ${formatNumber(qty)} کیلو از "${f.name}" تحویل و آماده ثبت نظر شد.`); 
            } else { alert("موجودی کافی نیست"); } 
        } else { alert("محصول در انبار یافت نشد"); } 
    } 
}
