<script>
// ==================== توابع تبدیل تاریخ ====================
function toPersianDate(gregorianDate) {
    if (!gregorianDate) return "نامشخص";
    let d = new Date(gregorianDate);
    if (isNaN(d.getTime())) return gregorianDate;
    let year = d.getFullYear(), month = d.getMonth() + 1, day = d.getDate();
    let gregorianDaysInMonth = [31,28,31,30,31,30,31,31,30,31,30,31];
    let persianDaysInMonth = [31,31,31,31,31,31,30,30,30,30,30,29];
    let gy = year - 1600, gm = month - 1, gd = day - 1;
    let gDayNo = 365 * gy + Math.floor((gy + 3) / 4) - Math.floor((gy + 99) / 100) + Math.floor((gy + 399) / 400);
    for (let i = 0; i < gm; i++) gDayNo += gregorianDaysInMonth[i];
    if (gm > 1 && ((gy % 4 === 0 && gy % 100 !== 0) || gy % 400 === 0)) gDayNo++;
    gDayNo += gd;
    let persianDayNo = gDayNo - 79;
    let persianYear = 0, persianMonth = 0, persianDay = 0;
    let persianNp = Math.floor(persianDayNo / 12053);
    persianDayNo %= 12053;
    persianYear = 979 + 33 * persianNp + 4 * Math.floor(persianDayNo / 1461);
    persianDayNo %= 1461;
    if (persianDayNo >= 366) {
        persianYear += Math.floor((persianDayNo - 1) / 365);
        persianDayNo = (persianDayNo - 1) % 365;
    }
    for (let i = 0; i < 11 && persianDayNo >= persianDaysInMonth[i]; i++) {
        persianDayNo -= persianDaysInMonth[i];
        persianMonth++;
    }
    persianDay = persianDayNo + 1;
    persianMonth++;
    return `${persianYear}/${persianMonth.toString().padStart(2,'0')}/${persianDay.toString().padStart(2,'0')}`;
}
function getCurrentPersianDateTime() { let now = new Date(); return `${toPersianDate(now.toISOString())} ${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')}`; }
function getCurrentPersianDate() { return toPersianDate(new Date().toISOString()); }
