    let type = prompt(`نوع حرکت را انتخاب کنید:\n1. ورود\n2. خروج`);
    if(type === "1") showPartMovementForm(partsInventory[idx].id, "in");
    else if(type === "2") showPartMovementForm(partsInventory[idx].id, "out");
