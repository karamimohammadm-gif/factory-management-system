        if(productBatch) { productBatch.batchCode = bn; productBatch.name = f.name; saveTraceData(); }
        alert(`✅ محصول "${f.name}" تایید شد.\n📦 مقدار: ${formatNumber(qty)} کیلو\n🔖 شماره بچ: ${bn} (کد سفارش)\n🔖 کد SKU: ${sku}`);
    } else { 
