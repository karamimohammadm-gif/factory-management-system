        .trace-modal-content { background: white; border-radius: 24px; width: 90%; max-width: 1200px; max-height: 85vh; overflow: auto; padding: 25px; direction: rtl; }
        .trace-chain { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin: 15px 0; }
