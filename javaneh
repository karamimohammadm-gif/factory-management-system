        .tabs-dropdown { position: absolute; top: 100%; right: 0; left: 0; background: white; border-radius: 0 0 20px 20px; box-shadow: 0 20px 40px rgba(0,0,0,0.15); z-index: 100; max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
        .tabs-dropdown.open { max-height: 600px; overflow-y: auto; }
        .tabs-dropdown .tab-btn { display: block; width: 100%; text-align: right; padding: 14px 24px; border-bottom: 1px solid #e8f0e8; border-radius: 0; }
        .tabs-dropdown .tab-btn:last-child { border-bottom: none; }
        .tabs-dropdown .tab-btn:hover { background: #f1f8e9; }
        .tabs-desktop { display: flex; flex-wrap: wrap; gap: 4px; padding: 0 20px; background: white; border-bottom: 2px solid #e8f5e9; }
        @media (max-width: 768px) { .tabs-desktop { display: none; } .tabs-dropdown-container { display: block; } }
        @media (min-width: 769px) { .tabs-dropdown-container { display: none; } .tabs-desktop { display: flex; } }
        .tab-btn { padding: 14px 20px; background: transparent; border: none; font-weight: 600; color: #4a6741; cursor: pointer; transition: all 0.2s; font-size: 0.85rem; border-radius: 16px 16px 0 0; white-space: nowrap; }
        .tab-btn:hover { background: #f1f8e9; color: #2e7d32; }
        .tab-btn.active { background: #2e7d32; color: white; }
