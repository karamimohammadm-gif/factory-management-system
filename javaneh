        try {
            let data = JSON.parse(e.target.result);
            if(data.formulas) formulas = data.formulas;
            if(data.devices) devices = data.devices;
            if(data.inventory) inventory = data.inventory;
            if(data.productInventory) productInventory = data.productInventory;
            if(data.productHistory) productHistory = data.productHistory;
            if(data.incomingMaterials) incomingMaterials = data.incomingMaterials;
            if(data.materialTests) materialTests = data.materialTests;
            if(data.finalQcTests) finalQcTests = data.finalQcTests;
            if(data.customerFeedbacks) customerFeedbacks = data.customerFeedbacks;
            if(data.materialRequests) materialRequests = data.materialRequests;
            if(data.partsInventory) partsInventory = data.partsInventory;
            if(data.partMovements) partMovements = data.partMovements;
            if(data.partRequests) partRequests = data.partRequests;
            if(data.materialPriceHistory) materialPriceHistory = data.materialPriceHistory;
            if(data.materialReturns) materialReturns = data.materialReturns;
            if(data.traceabilityData) traceabilityData = data.traceabilityData;
            if(data.systemSettings) systemSettings = data.systemSettings;
            if(data.systemLogs) systemLogs = data.systemLogs;
            if(data.productTypes) productTypes = data.productTypes;
            if(data.complaints) complaints = data.complaints;
            nextFormulaId = Math.max(...formulas.map(f=>f.id),0)+1;
            nextDeviceId = Math.max(...devices.map(d=>d.id),0)+1;
            nextInventoryId = Math.max(...inventory.map(i=>i.id),0)+1;
            nextProductId = Math.max(...productInventory.map(p=>p.id),0)+1;
            nextComplaintId = Math.max(...complaints.map(c=>c.id),0)+1;
            currentFormulaId = formulas[0]?.id || 1;
            saveLocal();
            renderAll();
            alert("✅ بازیابی با موفقیت انجام شد");
        } catch(err) { alert("❌ خطا در بازیابی فایل بکاپ"); }
    };
    reader.readAsText(file);
}
