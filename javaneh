        .tabs-dropdown-container { background: white; padding: 8px 20px; border-bottom: 2px solid #e8f5e9; position: relative; }
        .menu-icon { display: flex; flex-direction: column; justify-content: space-between; width: 32px; height: 24px; cursor: pointer; padding: 4px 0; }
