        .progress-thin { height: 6px; background: #e8e8e8; border-radius: 10px; margin-top: 8px; overflow: hidden; }
        .progress-fill { height: 100%; border-radius: 10px; transition: width 0.3s; }
        .operation-card { background: #f5f5f5; border-radius: 20px; padding: 30px; text-align: center; cursor: pointer; transition: 0.2s; border: 2px solid #e0e0e0; }
        .operation-card:hover { transform: translateY(-3px); border-color: #ff9800; }
        .report-stat-card { background: #f8faf5; border-radius: 16px; padding: 15px; text-align: center; border: 1px solid #e0e8dc; }
        .material-request-card { background: #e3f2fd; border-radius: 16px; padding: 15px; margin-bottom: 15px; border-right: 4px solid #2196f3; }
        .event-timeline { font-size: 0.7rem; color: #666; margin-top: 5px; padding-top: 5px; border-top: 1px dashed #ddd; }
        footer { text-align: center; margin-top: 30px; font-size: 0.7rem; color: #6b8c5c; }
