function renderComplaintsList() {
    let container = document.getElementById("complaintsList");
    if(!container) return;
    complaintsSearch = document.getElementById("complaintSearch")?.value.toLowerCase() || "";
    complaintsCurrentFilter = document.getElementById("complaintStatusFilter")?.value || "all";
    let filtered = complaints.filter(c => {
        if(complaintsCurrentFilter !== "all" && c.status !== complaintsCurrentFilter) return false;
        if(complaintsSearch && !c.customerName.toLowerCase().includes(complaintsSearch) && !c.subject.toLowerCase().includes(complaintsSearch) && !c.complaintNumber.toLowerCase().includes(complaintsSearch)) return false;
        return true;
    }).sort((a,b)=>new Date(b.createdAt)-new Date(a.createdAt));
    let itemsPerPage = complaintsItemsPerPage;
    let totalPages = Math.ceil(filtered.length / itemsPerPage);
    let start = (complaintsCurrentPage - 1) * itemsPerPage;
    let paginated = filtered.slice(start, start + itemsPerPage);
    if(filtered.length === 0) { container.innerHTML = "<div style='padding:40px;text-align:center;color:#999;'>هیچ شکایتی ثبت نشده است</div>"; let pagDiv = document.getElementById("complaintsPagination"); if(pagDiv) pagDiv.innerHTML = ""; return; }
    let html = '<div class="grid-2">';
    for(let c of paginated) {
        let priorityClass = c.priority === "high" ? "badge-danger" : (c.priority === "medium" ? "badge-warning" : "badge-info");
        let priorityText = c.priority === "high" ? "🔴 بالا" : (c.priority === "medium" ? "🟠 متوسط" : "🟢 پایین");
        let statusClass = c.status === "new" ? "new" : (c.status === "in_progress" ? "in-progress" : (c.status === "resolved" ? "resolved" : "closed"));
        let statusText = c.status === "new" ? "🆕 جدید" : (c.status === "in_progress" ? "🟡 در حال بررسی" : (c.status === "resolved" ? "✅ رفع شده" : "🔒 بسته شده"));
        let canEdit = (c.status === "new" && (currentUser?.role === "quality" || currentUser?.role === "admin")) || (c.status === "resolved" && (currentUser?.role === "sales" || currentUser?.role === "admin"));
        html += `<div class="complaint-card ${statusClass}">
            <div style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;">
                <div><strong>#${c.complaintNumber}</strong> - ${c.customerName}</div>
                <div><span class="badge ${priorityClass}">${priorityText}</span> <span class="badge badge-secondary">${statusText}</span></div>
            </div>
            <div><strong>موضوع:</strong> ${c.subject}</div>
            <div><strong>شرح:</strong> ${c.description.length > 100 ? c.description.substring(0,100) + "..." : c.description}</div>
            <div><strong>ارجاع به:</strong> ${c.assignedTo === "quality" ? "کنترل کیفی" : (c.assignedTo === "production" ? "تولید" : (c.assignedTo === "warehouse" ? "انبار" : "فروش"))}</div>
            <div><strong>تاریخ ثبت:</strong> ${c.persianCreatedAt}</div>
            ${c.actionTaken ? `<div><strong>اقدام اصلاحی:</strong> ${c.actionTaken.length > 80 ? c.actionTaken.substring(0,80) + "..." : c.actionTaken}</div>` : ''}
            ${c.finalResult ? `<div><strong>نتیجه:</strong> ${c.finalResult === "resolved" ? "رفع شده" : (c.finalResult === "partial" ? "رفع نسبی" : "عدم قابلیت رفع")}</div>` : ''}
            ${c.customerSatisfaction ? `<div><strong>⭐ امتیاز مشتری:</strong> ${"⭐".repeat(c.customerSatisfaction)} (${c.customerSatisfaction}/5)</div>` : ''}
            <div style="margin-top:12px;">
                ${canEdit ? `<button class="btn-primary btn-sm" onclick="editComplaint(${c.id})">✏️ ویرایش</button>` : ''}
                <button class="btn-outline btn-sm" onclick="showComplaintDetail(${c.id})">📋 جزئیات</button>
            </div>
        </div>`;
    }
    html += '</div>';
    container.innerHTML = html;
    let pagDiv = document.getElementById("complaintsPagination");
    if(pagDiv && totalPages > 1) {
        let pages = '';
        for(let i=1;i<=totalPages;i++) { pages += `<button class="${i===complaintsCurrentPage?'active':''}" onclick="goToComplaintsPage(${i})">${i}</button>`; }
        pages += `<span class="page-info">${start+1}-${Math.min(start+itemsPerPage, filtered.length)} از ${filtered.length}</span>`;
        pagDiv.innerHTML = pages;
    } else if(pagDiv && filtered.length > 0) { pagDiv.innerHTML = `<span class="page-info">${filtered.length} آیتم</span>`; }
}
function goToComplaintsPage(page) { complaintsCurrentPage = page; renderComplaintsList(); }
function renderComplaintStats() {
    let container = document.getElementById("complaintStats");
    if(!container) return;
    let total = complaints.length;
    let newCount = complaints.filter(c => c.status === "new").length;
    let inProgress = complaints.filter(c => c.status === "in_progress").length;
    let resolved = complaints.filter(c => c.status === "resolved").length;
    let closed = complaints.filter(c => c.status === "closed").length;
    let avgResolutionTime = 0;
    let resolvedComplaintsWithTime = complaints.filter(c => c.resolvedAt && c.createdAt);
    if(resolvedComplaintsWithTime.length > 0) {
        let totalDays = resolvedComplaintsWithTime.reduce((sum, c) => {
            let created = new Date(c.createdAt);
            let resolved = new Date(c.resolvedAt);
            let days = (resolved - created) / (1000 * 60 * 60 * 24);
            return sum + days;
        }, 0);
        avgResolutionTime = totalDays / resolvedComplaintsWithTime.length;
    }
    let avgSatisfaction = 0;
    let complaintsWithSatisfaction = complaints.filter(c => c.customerSatisfaction);
    if(complaintsWithSatisfaction.length > 0) {
        avgSatisfaction = complaintsWithSatisfaction.reduce((sum, c) => sum + c.customerSatisfaction, 0) / complaintsWithSatisfaction.length;
    }
    container.innerHTML = `
        <div class="report-stat-card"><div style="font-size:1.8rem;">${total}</div><div>کل شکایات</div></div>
        <div class="report-stat-card"><div style="font-size:1.8rem;color:#2196f3;">${newCount}</div><div>جدید</div></div>
        <div class="report-stat-card"><div style="font-size:1.8rem;color:#ff9800;">${inProgress}</div><div>در حال بررسی</div></div>
        <div class="report-stat-card"><div style="font-size:1.8rem;color:#4caf50;">${resolved}</div><div>رفع شده</div></div>
        <div class="report-stat-card"><div style="font-size:1.2rem;">${avgResolutionTime.toFixed(1)} روز</div><div>میانگین زمان رفع</div></div>
        <div class="report-stat-card"><div style="font-size:1.2rem;">${avgSatisfaction.toFixed(1)} / 5</div><div>میانگین رضایت</div></div>
    `;
}
