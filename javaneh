            if(formulaUpdated) updatedOrders.push(formula.name);
        }
    }
    if(updatedOrders.length > 0) { saveLocal(); renderAll(); alert(`✅ قیمت مواد در ${updatedOrders.length} سفارش بروزرسانی شد.`); }
    else { alert("هیچ سفارش در انتظار قیمتی برای بروزرسانی وجود ندارد"); }
}
