function applyMaterialPricesToAllPendingOrders() {
    if(currentUser?.role !== "admin") { alert("❌ فقط مدیر سیستم می‌تواند این عملیات را انجام دهد"); return; }
    let updatedOrders = [];
    for(let formula of formulas) {
        if(formula.status === STATUS_OBJ.WAITING_PRICING && !formula.priceFinalized) {
            let formulaUpdated = false;
            for(let material of formula.materials) {
                let inventoryItem = inventory.find(i => i.code === material.code);
                if(inventoryItem && inventoryItem.basePrice !== material.price) { material.price = inventoryItem.basePrice; formulaUpdated = true; }
